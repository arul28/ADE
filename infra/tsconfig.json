{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "aws-lambda", "sst"],
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "sst-env.d.ts",
    "sst.config.ts",
    "packages/**/*.ts"
  ]
}
