# Mintlify automatically ignores these files and directories:
# .git, .github, .claude, .agents, .idea, node_modules,
# README.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md

# Draft content
drafts/
*.draft.mdx

# ADE source code — not documentation
apps/
infra/
plans/
docs/
.ade/
packages/
.factory/

# Template files we're replacing
essentials/
ai-tools/
api-reference/
