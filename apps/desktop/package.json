{
  "name": "ade-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "generate:bootstrap": "node scripts/generate-bootstrap-defaults.cjs",
    "prebuild": "npm run generate:bootstrap",
    "predev": "npm run generate:bootstrap",
    "dev": "node ./scripts/ensure-electron.cjs && concurrently -k -n renderer,main,electron \"vite --port 5173\" \"tsup --watch\" \"wait-on tcp:5173 && wait-on file:dist/main/main.cjs && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsup && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "echo \"(todo)\"",
    "rebuild:native": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "@xyflow/react": "^12.5.0",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "monaco-editor": "^0.55.1",
    "node-cron": "^3.0.3",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.6.2",
    "react-router-dom": "^7.13.0",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.4.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "yaml": "^2.8.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^40.2.1",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^4.5.3",
    "vitest": "^0.34.6",
    "wait-on": "^7.2.0"
  }
}
