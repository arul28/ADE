{
  "name": "ade-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.cjs",
  "author": "",
  "license": "MIT",
  "scripts": {
    "predev": "node ./scripts/clear-vite-cache.cjs",
    "dev": "node ./scripts/ensure-electron.cjs && node ./scripts/dev.cjs",
    "build": "tsup && vite build",
    "dist:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:orchestrator-smoke": "vitest run src/main/services/orchestrator/orchestratorSmoke.test.ts --reporter=verbose",
    "test:orchestrator-complex-mock": "vitest run src/main/services/orchestrator/orchestratorSmoke.test.ts -t \"complex mock prompt\" --reporter=verbose",
    "mcp:dev": "npm --prefix ../mcp-server run dev -- --project-root ../..",
    "mcp:build": "npm --prefix ../mcp-server run build",
    "mcp:typecheck": "npm --prefix ../mcp-server run typecheck",
    "mcp:test": "npm --prefix ../mcp-server run test",
    "verify:ai-sdks": "node ./scripts/verify-ai-sdks.cjs",
    "lint": "echo \"(todo)\"",
    "rebuild:native": "electron-rebuild -f -w node-pty -w onnxruntime-node"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.33",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "1.27.1",
    "@openai/codex-sdk": "^0.104.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-virtual": "^3.13.21",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.5.0",
    "ai": "^6.0.94",
    "ai-sdk-provider-claude-code": "^3.4.2",
    "ai-sdk-provider-codex-cli": "^1.1.0",
    "chokidar": "^4.0.3",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "framer-motion": "^12.34.2",
    "geist": "^1.7.0",
    "lucide-react": "^0.563.0",
    "monaco-editor": "^0.55.1",
    "motion": "^12.34.2",
    "node-cron": "^3.0.3",
    "node-pty": "^1.1.0",
    "onnxruntime-node": "^1.24.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.2",
    "react-router-dom": "^7.13.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.13.0",
    "tailwind-merge": "^3.4.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.53",
    "@types/node": "^20.11.30",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.2.74",
    "@types/react-dom": "^18.2.24",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^40.2.1",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "jsdom": "^22.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^4.5.3",
    "vitest": "^0.34.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ade.desktop",
    "productName": "ADE",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.cjs",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/onnxruntime-node/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools"
    }
  }
}
