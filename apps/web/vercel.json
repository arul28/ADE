{
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- .",
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://ade-ac1c6011.mintlify.dev/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://ade-ac1c6011.mintlify.dev/docs/:match*"
    },
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}
